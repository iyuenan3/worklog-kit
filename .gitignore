# worklog 运行状态（无人值守安全网 + 本地观测，均不入 git）
.ingest-status.md
.ingest.lock
.ingest-history.log
GETTING_STARTED.md

# 导出产物（worklog-export 输出到 export/<日期>/，导出后自行移走，不入 git）
export/

# 敏感配置层（凭证只放这份）
worklog.config.local.yaml

# 密钥类兜底（红线：知识库 git 严禁私钥 / 凭证）
.env*
*.key
*.pem
id_rsa*
id_ed25519*
credentials*

# 编辑器 / 系统（.obsidian 只跟踪模板预置的两个文件，app 自动生成的其余配置不入 git）
.obsidian/*
!.obsidian/app.json
!.obsidian/community-plugins.json
.DS_Store
node_modules/
__pycache__/
*.pyc
